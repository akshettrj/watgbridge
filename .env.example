# Mode
# MODE=single

# Required – Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
TELEGRAM_TARGET_CHAT_ID=
# TELEGRAM_MAIN_BOT_TOKEN= # Required when MODE=multi

# Optional – Telegram
# TELEGRAM_SKIP_SETTING_COMMANDS=false
# TELEGRAM_SKIP_STARTUP_MESSAGE=false
# TELEGRAM_SILENT_CONFIRMATION=true
# TELEGRAM_CONFIRMATION_TYPE=emoji

# Optional – WhatsApp
# WHATSAPP_SESSION_NAME=watgbridge

# Optional – SQLite encryption (SQLCipher)
# 64 hex chars = 32-byte master secret. When set, HKDF derives keys for registry (multi), per-bridge children, or single-process sqlite (GORM + whatsmeow store).
# Existing plaintext .db files will not open until you remove the key or replace databases.
# WATG_SQLITE_MASTER_KEY=
# Advanced: pass derived key directly (normally set by the parent process for bridge children).
# WATG_SQLCIPHER_KEY_HEX=

# Optional – General
# TIME_ZONE=UTC
# TIME_FORMAT=02 Jan, 2006 - Mon @ 15:04
# DEBUG_MODE=false
# CONFIG_PATH=/data/config.yaml
